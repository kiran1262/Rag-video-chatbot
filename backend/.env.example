# Gemini (PRIMARY — chat + embeddings, via OpenAI-compatible endpoint)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI (FALLBACK — used only if Gemini is missing/unavailable)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o

# Instagram (required for Reels — IG blocks anonymous access)
# Export your logged-in IG cookies to a Netscape cookies.txt and point here.
INSTAGRAM_COOKIES_FILE=

# Pinecone (optional — omit to use the built-in in-memory vector store)
PINECONE_API_KEY=pk-your-key-here
PINECONE_INDEX_NAME=video-chunks
PINECONE_ENVIRONMENT=us-east-1

# Environment
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
